// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Settings {
  id                       Int       @id @default(1)
  githubToken              String?
  pollingInterval          Int       @default(60) // In seconds
  batchDelay               Int       @default(5) // In minutes
  julesApiKey              String?
  pruneDays                Int       @default(60)
  githubRateLimitRemaining Int?
  githubRateLimitReset     DateTime?
  webhookSecret            String?
  masterPasswordHash       String?
  setupCompleted           Boolean   @default(false)
  sessionSecret            String?

  healthApiToken           String?
  rssSecretToken           String?
  rssEvents                String? // JSON array of selected events
  updatedAt                DateTime  @updatedAt
  notificationRules        NotificationRule[]
}

model Repository {
  id                     String              @id @default(cuid())
  owner                  String
  name                   String
  isActive               Boolean             @default(true)
  autoMergeEnabled       Boolean             @default(false)
  requiredApprovals      Int                 @default(1)
  requireCI              Boolean             @default(true)
  mergeStrategy          String              @default("merge") // 'merge', 'squash', 'rebase'
  taskSourceType         String              @default("none") // 'none', 'local_folder', 'github_issues'
  taskSourcePath         String? // Path to folder if taskSourceType is 'local_folder'
  maxConcurrentTasks     Int                 @default(3) // Limits AI tasks running simultaneously
  julesPromptTemplate    String? // Template for the prompt
  julesChatForwardMode   String              @default("off") // 'off', 'always', 'failsafe'
  julesChatForwardDelay  Int                 @default(5) // In minutes
  aiSystemPrompt         String? // Top-level prompt for AI bots
  commentTemplate        String? // Markdown template for individual bot comments
  postAggregatedComments Boolean             @default(true)
  batchDelay             Int?
  branchWhitelist        String?
  branchBlacklist        String?
  includeCheckRuns       Boolean             @default(false)
  githubToken            String?
  requiredBots           String?
  aiBotUsernames         String? // Comma-separated list of AI agent usernames
  regressionDetection    Boolean             @default(true)
  regressionMatchMode    RegressionMatchMode @default(EXACT)
  infiniteLoopThreshold  Int                 @default(3) // 0 to disable
  maxDiffLines           Int                 @default(500) // 0 to disable
  complexityWeights      String? // JSON object for custom complexity weighting
  groupName              String?             @default("Default")
  architectureInfo       String?             @default("")
  createdAt              DateTime            @default(now())

  tasks           Task[]
  prLabelRules    PRLabelRule[]
  promptTemplates PromptTemplate[]
  agentFeedbacks  AgentFeedback[]
  flakyTestRules  FlakyTestRule[]
  errorRewriteRules ErrorRewriteRule[]
  resolutionTimes ResolutionTime[]

  @@unique([owner, name])
}

enum ProcessedCommentCategory {
  general
  lint
  security
  type_error
  test_failure
}

model TargetReviewer {
  id            String   @id @default(cuid())
  username      String   @unique
  isActive      Boolean  @default(true)
  noActionRegex String?
  createdAt     DateTime @default(now())
}

model ProcessedComment {
  id               String                    @id @default(cuid())
  commentId        BigInt
  nodeId           String?
  isSkipped        Boolean                   @default(false)
  source           String
  prNumber         Int
  repoOwner        String
  repoName         String
  author           String
  body             String
  postedAt         DateTime
  processedAt      DateTime                  @default(now())
  forwardedToJules Boolean                   @default(false)
  category         ProcessedCommentCategory?
  isRegression     Boolean                   @default(false)
  isPruned         Boolean                   @default(false)

  @@unique([commentId, source])
  @@index([repoOwner, repoName, prNumber, postedAt])
  @@index([postedAt])
  @@index([category])
}

model BatchSession {
  id               String    @id @default(cuid())
  prNumber         Int
  repoOwner        String
  repoName         String
  firstSeenAt      DateTime  @default(now())
  isProcessed      Boolean   @default(false)
  isProcessing     Boolean   @default(false)
  forceProcess     Boolean   @default(false)
  includeCheckRuns Boolean   @default(false)
  isHighPriority   Boolean   @default(false)
  manualPrompt     String?
  resolvedAt       DateTime? // When the PR was closed or merged
  resolved         Boolean   @default(false)
  isPaused         Boolean   @default(false)
  hasConflict      Boolean   @default(false)
  loopCount        Int       @default(0)
  lastPromptId     String? // To track which prompt template was used
  lastPromptVars   String? // To track variables used in last prompt

  @@index([prNumber, repoOwner, repoName, isProcessed])
}

model AutoMergeLog {
  id        String   @id @default(cuid())
  repoOwner String
  repoName  String
  prNumber  Int
  status    String // 'SUCCESS', 'FAILED', 'PAUSED'
  message   String?
  createdAt DateTime @default(now())

  @@index([repoOwner, repoName, prNumber])
}

model Task {
  id                String     @id @default(cuid())
  repositoryId      String
  repository        Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  title             String
  body              String?
  status            String     @default("backlog") // backlog, todo, in_progress, in_review, blocked, done
  source            String     @default("manual") // local_folder, github_issue, manual
  priority          Int        @default(0) // Higher number = higher priority
  githubIssueNumber Int?
  julesSessionId    String?
  julesSessionState String?
  julesSessionUrl   String?
  julesSessionPrUrl String?
  julesSessionCreatedAt DateTime?
  prNumber          Int?
  contextFiles      String? // JSON array of file paths
  dependsOnId       String?
  dependsOn         Task?      @relation("TaskDependencies", fields: [dependsOnId], references: [id])
  dependentTasks    Task[]     @relation("TaskDependencies")
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([repositoryId, status])
  @@index([julesSessionState])
}

model WebhookSignal {
  id        String   @id @default(cuid())
  repoOwner String
  repoName  String
  prNumber  Int
  createdAt DateTime @default(now())

  @@unique([repoOwner, repoName, prNumber])
  @@index([createdAt, repoOwner, repoName])
}

enum PRLabelRuleEvent {
  processing_start
  processing_done
}

model PRLabelRule {
  id           String           @id @default(cuid())
  repositoryId String
  repository   Repository       @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  event        PRLabelRuleEvent
  labelName    String
  createdAt    DateTime         @default(now())

  @@unique([repositoryId, event, labelName])
  @@index([repositoryId])
}

model RateLimitLog {
  id        String   @id @default(cuid())
  remaining Int
  limit     Int
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model AIAgentAction {
  id        String   @id @default(cuid())
  repoOwner String
  repoName  String
  prNumber  Int
  isSuccess Boolean
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model BotAgentMapping {
  id        String   @id @default(cuid())
  botSource String   @unique
  agentName String
  role      String?
  createdAt DateTime @default(now())
}

model PromptTemplate {
  id           String     @id @default(cuid())
  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  name         String
  isActive     Boolean    @default(true)
  systemPrompt String?
  template     String
  createdAt    DateTime   @default(now())

  @@unique([repositoryId, name])
  @@index([repositoryId, isActive])
}

enum RegressionMatchMode {
  EXACT
  TYPE
  FUZZY
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // e.g., "UPDATE_SETTINGS", "IMPORT_CONFIG"
  entity    String?  // e.g., "Settings", "Repository"
  details   String?  // JSON stringified details
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model NotificationRule {
  id          String   @id @default(cuid())
  settingsId  Int      @default(1)
  settings    Settings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  type        String   // discord, telegram, ntfy, gotify, smtp, webhook
  name        String
  targetUrl   String?  // Webhook URL, Ntfy URL, Gotify URL
  token       String?  // Telegram Token, Gotify Token
  chatId      String?  // Telegram Chat ID
  smtpHost    String?
  smtpPort    Int?
  smtpUser    String?
  smtpPass    String?
  smtpFrom    String?
  smtpTo      String?
  events      String   // JSON array of event types (SYSTEM_ERROR, PR_AGGREGATED, AI_TASK_COMPLETED, DAILY_SUMMARY, etc.)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([settingsId, isActive])
}

// --- Category Q: Feedback Loops & Learning Systems ---

model AgentFeedback {
  id           String     @id @default(cuid())
  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  agentName    String
  prNumber     Int
  commentId    BigInt?    // GitHub Comment ID if applicable
  upvotes      Int        @default(0)
  downvotes    Int        @default(0)
  promptUsed   String?    // The prompt or prompt template ID that generated this
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([repositoryId, agentName])
}

model FlakyTestRule {
  id           String     @id @default(cuid())
  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  name         String?    // Friendly name
  testNameRegex String    // Regex to match the flaky test warning
  isActive     Boolean    @default(true)
  ignoreCount  Int        @default(0) // How many times it was ignored
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([repositoryId, isActive])
}

model ErrorRewriteRule {
  id           String     @id @default(cuid())
  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  name         String?
  errorRegex   String     // Regex to match the vague error
  rewriteTo    String     // Human readable text to replace or append
  isActive     Boolean    @default(true)
  applyCount   Int        @default(0) // How many times it was applied
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([repositoryId, isActive])
}

model ResolutionTime {
  id           String     @id @default(cuid())
  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  prNumber     Int
  category     String     // Type of error (e.g. 'lint', 'security', 'general')
  firstSeenAt  DateTime
  resolvedAt   DateTime   // When the PR was merged
  durationSecs Int        // TTR in seconds
  createdAt    DateTime   @default(now())

  @@index([repositoryId, category])
}
